{
  "name": "claude-clone",
  "version": "1.0.0",
  "description": "Agentic Coding CLI (Claude Clone)",
  "bin": {
    "claude-clone": "./dist/index.js"
  },
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.tsx",
    "build": "bun build ./src/index.tsx --compile --outfile ./dist/index",
    "start": "bun run ./dist/index.js"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node-cron": "^3.0.11"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentui/core": "^0.1.103",
    "@opentui/react": "^0.1.103",
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "node-cron": "^4.2.1",
    "react": "^19.2.4",
    "tree-node-cli": "^3.0.0"
  }
}